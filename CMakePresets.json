{
    "version": 8,
    "configurePresets": [
        {
            "name": "nina",
            "displayName": "Clang 22.1.1 x86_64-pc-linux-gnu",
            "description": "正在使用编译器: C = /usr/bin/clang-22, CXX = /usr/bin/clang++-22",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "/usr/bin/clang-22",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++-22",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}